background = 000000
theme = lackluster

font-family = Berkeley Mono
font-size = 10

shell-integration-features = no-cursor, no-sudo, no-title

# annoying "confirm close" dialog
confirm-close-surface = false

gtk-tabs-location = bottom
gtk-wide-tabs = false
gtk-titlebar = false
adw-toolbar-style = raised-border
window-decoration = auto

# keybinds
keybind = ctrl+comma=unbind 
