{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 0,
  "height": 26,
  "modules-left": [
    "custom/arch",
    "custom/workspace-listener",
    "custom/workspace1",
    "custom/workspace2",
    "custom/workspace3",
    "custom/workspace4",
    "custom/workspace5",
    "custom/workspace6",
