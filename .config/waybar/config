    "pulseaudio",
    "cpu",
    "battery"
  ],
  "custom/workspace-listener": {
    "exec": "python3 /home/x6a6471/.config/waybar/workspace-listener.py",
    "format": "",
    "tooltip": false
  },
  "custom/workspace1": {
    "exec": "sh /home/x6a6471/.config/waybar/workspace.sh 1 I 1",
    "return-type": "json",
    "signal": 8,
    "hide-empty-text": true,
    "format": "{text}",
    "tooltip": false,
    "on-click": "hyprctl dispatch 'hl.dsp.focus({ workspace = 1 })' >/dev/null 2>&1"
